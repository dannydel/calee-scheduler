@*
    Demo-only shortcut help dialog. Reads from SchedulerShortcuts.DefaultMap so
    the help table is always in sync with whatever the library actually wires
    (no separate source of truth). Wired to OnHelpRequested on the demo pages —
    pressing "?" while the scheduler has focus opens this dialog.

    Per ADR-0010 the library ships no dialogs; this demonstrates the consumer-
    rendered help-screen pattern the ADR-0013 §"DefaultShortcutMap" notes
    callers can build by iterating the public default map.
*@

@using Calee.Scheduler.Contracts
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@inject IJSRuntime JS

@if (IsVisible)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-ink/40 p-4"
         role="presentation"
         @onclick="HandleBackdropClickAsync">
        <div class="bg-surface rounded-lg shadow-2xl max-w-lg w-full p-6 max-h-[80vh] overflow-y-auto"
             role="dialog"
             aria-modal="true"
             aria-labelledby="shortcut-help-title"
             @onclick:stopPropagation="true"
             @onkeydown="HandleKeyDownAsync">

            <h2 id="shortcut-help-title" class="font-display text-2xl text-ink mb-1">
                Keyboard shortcuts
            </h2>
            <p class="font-sans text-xs text-ink-muted mb-5">
                Iterated from <code class="font-mono">SchedulerShortcuts.DefaultMap</code> at
                render time — same source the library dispatches against.
            </p>

            <table class="w-full font-sans text-sm">
                <thead>
                    <tr class="text-xs uppercase tracking-wider text-ink-muted border-b border-line">
                        <th class="text-left py-2 pr-3 font-medium">Key</th>
                        <th class="text-left py-2 font-medium">Command</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var binding in SchedulerShortcuts.DefaultMap)
                    {
                        <tr class="border-b border-line/40">
                            <td class="py-1.5 pr-3 font-mono text-xs">@binding.Key</td>
                            <td class="py-1.5 text-ink-muted">@binding.CommandId</td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="flex justify-end pt-4">
                <button type="button"
                        class="px-4 py-2 text-sm font-sans bg-accent text-white rounded-md hover:bg-accent/90 transition-colors"
                        @ref="_closeButtonRef"
                        @onclick="HandleCloseAsync">
                    Close
                </button>
            </div>
        </div>
    </div>
}

@code {
    /// <summary>Whether the dialog is rendered. Caller toggles from its own state.</summary>
    [Parameter] public bool IsVisible { get; set; }

    /// <summary>Fires when the user clicks Close, the backdrop, or presses Escape.</summary>
    [Parameter] public EventCallback OnClose { get; set; }

    private const string FocusModulePath = "./js/dialog-focus.js";

    private ElementReference _closeButtonRef;
    private IJSObjectReference? _focusModule;
    private bool _previouslyVisible;
    private bool _focusOnOpen;

    protected override void OnParametersSet()
    {
        if (IsVisible && !_previouslyVisible)
        {
            _focusOnOpen = true;
        }

        _previouslyVisible = IsVisible;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!IsVisible || !_focusOnOpen)
        {
            return;
        }

        _focusOnOpen = false;

        try
        {
            _focusModule ??= await JS.InvokeAsync<IJSObjectReference>("import", FocusModulePath);
            await _focusModule.InvokeAsync<bool>("captureInvokerAndFocus", _closeButtonRef);
        }
        catch (JSException)
        {
            await FocusCloseButtonAsync();
        }
        catch (InvalidOperationException)
        {
            await FocusCloseButtonAsync();
        }
    }

    private async Task HandleCloseAsync()
    {
        await RestoreInvokerFocusAsync();
        await OnClose.InvokeAsync();
    }

    private Task HandleBackdropClickAsync() => HandleCloseAsync();

    private async Task HandleKeyDownAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            await HandleCloseAsync();
        }
    }

    private async Task RestoreInvokerFocusAsync()
    {
        if (_focusModule is null)
        {
            return;
        }

        try
        {
            await _focusModule.InvokeAsync<bool>("restoreCapturedInvoker");
        }
        catch (JSException)
        {
            // Focus restoration is best effort; closing the dialog must not depend on it.
        }
        catch (InvalidOperationException)
        {
            // The renderer may already be disposed during navigation.
        }
    }

    private async Task FocusCloseButtonAsync()
    {
        try
        {
            await _closeButtonRef.FocusAsync();
        }
        catch (InvalidOperationException)
        {
            // The dialog can be removed before a delayed render completes.
        }
        catch (JSException)
        {
            // The browser may be navigating away while the dialog is opening.
        }
    }
}
